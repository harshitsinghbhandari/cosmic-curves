# ===========================================
# CosmosCurves Environment Configuration
# ===========================================
# Copy this to .env and customize for your setup
# ===========================================

# Environment: "development" or "production"
NODE_ENV=development

# Backend API URL (where FastAPI is running)
VITE_API_BASE=http://localhost:8000

# Phone PWA URL (for QR code generation in backend)
PHONE_PWA_URL=http://localhost:3001

# Frontend URLs (for backend CORS and redirects)
LAPTOP_PWA_URL=http://localhost:3000
